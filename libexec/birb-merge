#!/usr/bin/env bash
# summary: Merge GitHub pull requests locally
#
# Usage:
#   birb merge <PR_NUMBER> [OPTIONS]
#
# Options:
#   -s, --switch <branch>   Merge into a different branch than the PR's base
#   --no-commit             Merge but don't commit (inspect/tweak first)
#   --no-thanks             Skip the "thank the author" suggestion
#   --force-squash          Force squash even with multiple authors
#   -h, --help              Show this help
#
# Requirements: gh (GitHub CLI), git, jq

set -euo pipefail

# ─── Colors ──────────────────────────────────────────────────────────────────

RESET='\033[0m'
BOLD='\033[1m'
DIM='\033[2m'
ITALIC='\033[3m'

BLACK='\033[0;30m'
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[0;37m'

B_RED='\033[1;31m'
B_GREEN='\033[1;32m'
B_YELLOW='\033[1;33m'
B_BLUE='\033[1;34m'
B_MAGENTA='\033[1;35m'
B_CYAN='\033[1;36m'

BRIGHT_BLUE='\033[0;94m'
BRIGHT_MAGENTA='\033[0;95m'
BRIGHT_CYAN='\033[0;96m'

BG_BLUE='\033[44m'
BG_MAGENTA='\033[45m'

# ─── Output helpers ──────────────────────────────────────────────────────────

info()    { echo -e "${CYAN}▸${RESET} $*"; }
ok()      { echo -e "${B_GREEN}✔${RESET} $*"; }
warn()    { echo -e "${B_YELLOW}⚠${RESET} $*"; }
error()   { echo -e "${B_RED}✖${RESET} $*" >&2; }
die()     { error "$@"; exit 1; }
q()       { echo -e "${B_MAGENTA}?${RESET} $*"; }

section() {
    echo ""
    echo -e "${BOLD}${BRIGHT_BLUE}┌─ $* ${RESET}${DIM}${BLUE}$(printf '─%.0s' $(seq 1 $((60 - ${#1}))))${RESET}"
}

header() {
    local title="$1"
    echo ""
    echo -e "${BOLD}${B_MAGENTA}  ♢ birb merge${RESET}  ${DIM}— $title${RESET}"
    echo -e "${DIM}${BLUE}  $(printf '━%.0s' $(seq 1 56))${RESET}"
}

ask_yes_no() {
    local prompt="$1" default="${2:-y}"
    local yn hint
    if [[ "$default" == "y" ]]; then
        hint="${DIM}[Y/n]${RESET}"
    else
        hint="${DIM}[y/N]${RESET}"
    fi
    read -rp "$(echo -e "${B_MAGENTA}?${RESET} ${BOLD}$prompt${RESET} $hint ")" yn
    yn="${yn:-$default}"
    [[ "$yn" =~ ^[Yy] ]]
}

# Run a command, or print it in dry-run mode. Use for any state-mutating
# operation (git commit/tag/push, gh edit/close/comment, file writes).
# Writes the dry-run line to /dev/tty when available, so callers that pipe
# stdout/stderr to /dev/null still see what would have run.
run() {
    if [[ "${DRY_RUN:-false}" == true ]]; then
        local arg parts=()
        for arg in "$@"; do
            if [[ -z "$arg" || "$arg" =~ [[:space:]\"\'\$\\] ]]; then
                arg="${arg//\'/\'\\\'\'}"
                parts+=("'$arg'")
            else
                parts+=("$arg")
            fi
        done
        local msg="  ${DIM}[dry-run]${RESET} ${parts[*]}"
        # Try /dev/tty so the line survives caller >/dev/null redirections;
        # fall back to stdout if the controlling terminal isn't available.
        echo -e "$msg" > /dev/tty 2>/dev/null || echo -e "$msg"
        return 0
    fi
    "$@"
}

# ─── Usage ───────────────────────────────────────────────────────────────────

usage() {
    cat <<EOF
$(echo -e "${BOLD}${B_MAGENTA}birb merge${RESET}") — Merge a GitHub PR via gh pr merge, then run the local
wrap-up (pull, version bump + tag, post-merge push, update project board,
thank author).

The merge itself runs on GitHub's side so the PR ends up flagged as
MERGED (not just closed), referenced issues auto-close, and any stacked
PR is auto-rebased onto the merged base rather than getting orphaned.

$(echo -e "${BOLD}Usage:${RESET}")
  birb merge <PR_NUMBER> [OPTIONS]

$(echo -e "${BOLD}Options:${RESET}")
  -s, --switch <branch>   Re-base the PR onto a different branch on GitHub
                          before merging
  --no-commit             Skip the GitHub merge — perform a local
                          'git merge --no-commit' for inspection only
  --no-thanks             Skip the "thank the author" comment
  --force-squash          Use --squash even with multiple authors
  --no-push               Skip pushing the post-merge version-bump commit
                          and any new tag
  --no-close-pr           Skip the post-merge PR confirmation step
  --no-close-issue        Skip the explicit issue-close pass (GitHub
                          auto-closes "closes #N" issues on merge anyway)
  --no-project-update     Skip moving project items to "Done"
  --dry-run               Print every mutating command without running it
  -h, --help              Show this help

$(echo -e "${BOLD}Examples:${RESET}")
  birb merge 42
  birb merge 42 --switch=main
  birb merge 42 --no-commit
  birb merge 42 --dry-run
  birb merge 42 --no-project-update --no-close-issue
EOF
    exit 0
}

# ─── Remote / repo detection ─────────────────────────────────────────────────

get_remote() {
    local remote
    remote="${GH_REMOTE:-}"
    [[ -n "$remote" ]] && echo "$remote" && return
    remote="$(git config --get gh.remote 2>/dev/null || true)"
    [[ -n "$remote" ]] && echo "$remote" && return
    echo "origin"
}

get_repo_slug() {
    local remote="$1"
    local url owner name
    url="$(git remote get-url "$remote" 2>/dev/null)" || die "Remote '$remote' not found"

    if [[ "$url" =~ git@github\.com:([^/]+)/(.+)$ ]]; then
        owner="${BASH_REMATCH[1]}"
        name="${BASH_REMATCH[2]%.git}"
        echo "$owner/$name"
    elif [[ "$url" =~ github\.com/([^/]+)/(.+)$ ]]; then
        owner="${BASH_REMATCH[1]}"
        name="${BASH_REMATCH[2]%.git}"
        echo "$owner/$name"
    else
        die "Cannot parse GitHub repo from remote URL: $url"
    fi
}

# ─── Conventional commit types ───────────────────────────────────────────────

COMMIT_TYPES=(
    "feat|New feature"
    "fix|Bug fix"
    "docs|Documentation"
    "security|Security fix"
    "deps|Dependencies"
    "refactor|Refactoring"
    "perf|Performance"
    "chore|Maintenance"
    "style|Formatting"
    "test|Tests"
    "build|Build system"
    "ci|CI/CD"
    "revert|Revert"
)

select_commit_type() {
    section "Change type"
    local i=1 entry key desc
    for entry in "${COMMIT_TYPES[@]}"; do
        key="${entry%%|*}"
        desc="${entry#*|}"
        printf "  ${B_MAGENTA}%2d)${RESET} ${BOLD}%-10s${RESET} ${DIM}— %s${RESET}\n" "$i" "$key" "$desc"
        i=$((i+1))
    done
    echo ""
    local choice
    read -rp "$(echo -e "${B_MAGENTA}?${RESET} ${BOLD}Type${RESET} ${DIM}[1-${#COMMIT_TYPES[@]}, name, or empty to skip]:${RESET} ")" choice

    [[ -z "$choice" ]] && { SELECTED_TYPE=""; return; }

    if [[ "$choice" =~ ^[0-9]+$ ]]; then
        local idx=$((choice - 1))
        if [[ "$idx" -ge 0 && "$idx" -lt "${#COMMIT_TYPES[@]}" ]]; then
            SELECTED_TYPE="${COMMIT_TYPES[$idx]%%|*}"
            ok "Selected: ${B_MAGENTA}${SELECTED_TYPE}${RESET}"
            return
        fi
    fi

    for entry in "${COMMIT_TYPES[@]}"; do
        key="${entry%%|*}"
        if [[ "$key" == "$choice" ]]; then
            SELECTED_TYPE="$key"
            ok "Selected: ${B_MAGENTA}${SELECTED_TYPE}${RESET}"
            return
        fi
    done

    warn "Unknown type '$choice', skipping prefix"
    SELECTED_TYPE=""
}

# ─── Labels ──────────────────────────────────────────────────────────────────

manage_labels() {
    section "Labels"

    local current_labels
    current_labels="$(echo "$PR_JSON" | jq -r '.labels[].name' | sort)"

    if [[ -n "$current_labels" ]]; then
        echo -e "${DIM}Current labels:${RESET}"
        local label
        while IFS= read -r label; do
            echo -e "  ${B_GREEN}●${RESET} ${GREEN}$label${RESET}"
        done <<< "$current_labels"
    else
        echo -e "${DIM}No labels currently applied.${RESET}"
    fi
    echo ""

    # NB: explicit `return 0` — under `set -e`, a bare `return` propagates
    # ask_yes_no's non-zero status and aborts the whole script when the user
    # declines the prompt.
    ask_yes_no "Modify labels before merge?" "n" || return 0

    local available
    available="$(gh api "repos/$REPO/labels?per_page=100" --jq '.[].name' 2>/dev/null | sort)" \
        || { warn "Could not fetch labels"; return; }

    if [[ -z "$available" ]]; then
        warn "No labels available in this repo"
        return
    fi

    echo ""
    echo -e "${DIM}Toggle by number (already applied shown with ${B_GREEN}●${RESET}${DIM}):${RESET}"
    local i=1 label marker
    local -a labels_arr=()
    while IFS= read -r label; do
        labels_arr+=("$label")
        marker=" "
        if echo "$current_labels" | grep -qx "$label" 2>/dev/null; then
            marker="${B_GREEN}●${RESET}"
        fi
        printf "  $marker ${B_MAGENTA}%2d)${RESET} %s\n" "$i" "$label"
        i=$((i+1))
    done <<< "$available"
    echo ""

    local choices num idx
    read -rp "$(echo -e "${B_MAGENTA}?${RESET} ${BOLD}Numbers to toggle${RESET} ${DIM}(space-separated, empty to cancel):${RESET} ")" choices
    [[ -z "$choices" ]] && return

    for num in $choices; do
        if [[ "$num" =~ ^[0-9]+$ ]]; then
            idx=$((num - 1))
            if [[ "$idx" -ge 0 && "$idx" -lt "${#labels_arr[@]}" ]]; then
                label="${labels_arr[$idx]}"
                if echo "$current_labels" | grep -qx "$label" 2>/dev/null; then
                    if run gh pr edit "$PR_NUMBER" --repo "$REPO" --remove-label "$label" >/dev/null 2>&1; then
                        info "Removed: ${RED}$label${RESET}"
                    else
                        warn "Failed to remove: $label"
                    fi
                else
                    if run gh pr edit "$PR_NUMBER" --repo "$REPO" --add-label "$label" >/dev/null 2>&1; then
                        info "Added: ${GREEN}$label${RESET}"
                    else
                        warn "Failed to add: $label"
                    fi
                fi
            fi
        fi
    done
}

# ─── Version bump ────────────────────────────────────────────────────────────

detect_version_kind() {
    if [[ -f package.json ]] && jq -e '.version' package.json >/dev/null 2>&1; then
        echo "npm"
    elif [[ -f composer.json ]] && jq -e '.version' composer.json >/dev/null 2>&1; then
        echo "composer"
    elif [[ -f VERSION ]]; then
        echo "version-file"
    elif git describe --tags --abbrev=0 >/dev/null 2>&1; then
        echo "git-tag"
    else
        echo "none"
    fi
}

get_current_version() {
    case "$1" in
        npm)          jq -r '.version // empty' package.json ;;
        composer)     jq -r '.version // empty' composer.json ;;
        version-file) tr -d '[:space:]' < VERSION ;;
        git-tag)      git describe --tags --abbrev=0 2>/dev/null | sed 's/^v//' ;;
    esac
}

bump_semver() {
    local version="$1" kind="$2"
    local major minor patch
    IFS='.' read -r major minor patch <<< "$version"
    major="${major:-0}"; minor="${minor:-0}"; patch="${patch:-0}"
    # Strip any pre-release suffix
    patch="${patch%%-*}"
    case "$kind" in
        major) echo "$((major+1)).0.0" ;;
        minor) echo "${major}.$((minor+1)).0" ;;
        patch) echo "${major}.${minor}.$((patch+1))" ;;
    esac
}

apply_version_bump() {
    local new="$1" kind="$2"
    if [[ "$DRY_RUN" == true ]]; then
        case "$kind" in
            npm)          run sh -c "jq --arg v '$new' '.version = \$v' package.json > package.json && git add package.json" ;;
            composer)     run sh -c "jq --arg v '$new' '.version = \$v' composer.json > composer.json && git add composer.json" ;;
            version-file) run sh -c "echo '$new' > VERSION && git add VERSION" ;;
        esac
        return
    fi
    case "$kind" in
        npm)
            local tmp
            tmp="$(jq --arg v "$new" '.version = $v' package.json)"
            echo "$tmp" > package.json
            git add package.json
            if [[ -f package-lock.json ]]; then
                tmp="$(jq --arg v "$new" '.version = $v | (.packages[""].version = $v)' package-lock.json 2>/dev/null)" \
                    && echo "$tmp" > package-lock.json \
                    && git add package-lock.json
            fi
            ;;
        composer)
            local tmp
            tmp="$(jq --arg v "$new" '.version = $v' composer.json)"
            echo "$tmp" > composer.json
            git add composer.json
            ;;
        version-file)
            echo "$new" > VERSION
            git add VERSION
            ;;
    esac
}

manage_version_bump() {
    section "Version bump"

    local kind current
    kind="$(detect_version_kind)"

    if [[ "$kind" == "none" ]]; then
        info "No version source detected. Skipping."
        return
    fi

    current="$(get_current_version "$kind")"

    if [[ -z "$current" ]]; then
        info "No current version found. Skipping."
        return
    fi

    echo -e "${DIM}Project type:${RESET}    ${BOLD}$kind${RESET}"
    echo -e "${DIM}Current version:${RESET} ${BOLD}${B_MAGENTA}$current${RESET}"
    echo ""

    local patch_v minor_v major_v
    patch_v="$(bump_semver "$current" patch)"
    minor_v="$(bump_semver "$current" minor)"
    major_v="$(bump_semver "$current" major)"

    echo -e "  ${B_MAGENTA}1)${RESET} ${BOLD}patch${RESET}   ${DIM}→${RESET}  ${GREEN}$patch_v${RESET}    ${DIM}(bug fix)${RESET}"
    echo -e "  ${B_MAGENTA}2)${RESET} ${BOLD}minor${RESET}   ${DIM}→${RESET}  ${YELLOW}$minor_v${RESET}    ${DIM}(new feature, backwards-compatible)${RESET}"
    echo -e "  ${B_MAGENTA}3)${RESET} ${BOLD}major${RESET}   ${DIM}→${RESET}  ${RED}$major_v${RESET}    ${DIM}(breaking changes)${RESET}"
    echo -e "  ${B_MAGENTA}4)${RESET} ${BOLD}custom${RESET}"
    echo -e "  ${B_MAGENTA}5)${RESET} ${BOLD}skip${RESET}"
    echo ""

    local choice new_version=""
    read -rp "$(echo -e "${B_MAGENTA}?${RESET} ${BOLD}Bump${RESET} ${DIM}[1-5, default: 5]:${RESET} ")" choice
    choice="${choice:-5}"

    case "$choice" in
        1) new_version="$patch_v" ;;
        2) new_version="$minor_v" ;;
        3) new_version="$major_v" ;;
        4) read -rp "$(echo -e "${B_MAGENTA}?${RESET} ${BOLD}New version:${RESET} ")" new_version ;;
        *) info "Skipping version bump."; return ;;
    esac

    [[ -z "$new_version" ]] && { info "No version provided, skipping."; return; }

    if [[ "$kind" != "git-tag" ]]; then
        apply_version_bump "$new_version" "$kind"
        if run git commit -m "chore: bump version to $new_version" >/dev/null; then
            ok "Bumped ${kind} to ${BOLD}${B_MAGENTA}$new_version${RESET}"
        else
            warn "Version bump commit failed"
        fi
    fi

    if ask_yes_no "Create git tag v${new_version}?" "y"; then
        if run git tag "v${new_version}" 2>/dev/null; then
            NEW_TAG="v${new_version}"
            ok "Tagged ${BOLD}${B_MAGENTA}v${new_version}${RESET}"
        elif [[ "$DRY_RUN" != true ]] && git rev-parse "v${new_version}" >/dev/null 2>&1; then
            # Tag already exists locally — re-runs (e.g. after a failed push)
            # should still push the existing tag rather than silently dropping it.
            NEW_TAG="v${new_version}"
            info "Tag ${BOLD}${B_MAGENTA}v${new_version}${RESET} already exists — will push existing tag"
        else
            warn "Could not create tag v${new_version}"
        fi
    fi
}

# ─── Linked-issue extraction ─────────────────────────────────────────────────

# Greps PR body for GitHub closing keywords + #N and prints unique issue
# numbers, one per line. Returns nothing if the PR has no body or matches.
extract_linked_issues() {
    local body
    body="$(echo "$PR_JSON" | jq -r '.body // ""')"
    [[ -z "$body" ]] && return 0
    echo "$body" \
        | grep -oiE '(close[sd]?|fix(es|ed)?|resolve[sd]?)[[:space:]]+#[0-9]+' \
        | grep -oE '[0-9]+$' \
        | awk '!seen[$0]++'
}

# ─── GitHub-side merge ───────────────────────────────────────────────────────

# Performs the merge via `gh pr merge`, i.e. on GitHub's own side. This is
# the only way to:
#   • Mark the PR as MERGED (not just CLOSED). A local squash + push leaves
#     the squashed SHA unrelated to the PR head, so GitHub flags the PR as
#     plainly closed.
#   • Auto-rebase stacked PRs. When --delete-branch removes the head branch,
#     GitHub re-targets any PR whose base was that branch onto its parent.
#     Manual branch deletion (gh pr close --delete-branch) skips that step
#     and instead auto-CLOSES the stacked PRs — the bug we're fixing.
#   • Auto-close issues referenced via "closes #N" in the PR body.
merge_on_github() {
    section "Merging on GitHub"

    # --switch: re-target the PR on GitHub before merging, so gh pr merge
    # lands on the requested branch instead of the PR's original base.
    if [[ -n "$SWITCH_BRANCH" && "$SWITCH_BRANCH" != "$PR_BASE_REF" ]]; then
        info "Re-basing PR onto ${B_GREEN}${SWITCH_BRANCH}${RESET} (was ${YELLOW}${PR_BASE_REF}${RESET})…"
        if ! run gh pr edit "$PR_NUMBER" --repo "$REPO" --base "$SWITCH_BRANCH" >/dev/null; then
            die "Failed to change PR base to $SWITCH_BRANCH"
        fi
    fi

    local merge_args=("pr" "merge" "$PR_NUMBER" "--repo" "$REPO" "--subject" "$MERGE_MSG")
    if [[ "$SQUASH" == true ]]; then
        # Empty --body keeps the squash commit clean (default is the
        # concatenation of every PR commit message).
        merge_args+=("--squash" "--body" "")
    else
        merge_args+=("--merge")
    fi

    # Only delete the branch when the PR head is in the same repo (gh would
    # error trying to delete a fork's branch). Deleting the head branch is
    # what triggers GitHub's auto-rebase of stacked PRs.
    local same_repo
    same_repo="$(echo "$PR_JSON" | jq -r '(.head.repo.full_name // "") == (.base.repo.full_name // "")')"
    [[ "$same_repo" == "true" ]] && merge_args+=("--delete-branch")

    info "Asking GitHub to ${SQUASH:+squash-}merge PR #${PR_NUMBER}…"
    if ! run gh "${merge_args[@]}"; then
        die "GitHub refused the merge. Check for conflicts, required reviews, or failing checks; then re-run."
    fi

    PR_CLOSE_STATUS="merged"

    if [[ "$DRY_RUN" == true ]]; then
        SQUASH_SHA="<dry-run-sha>"
        ok "Would merge PR #${PR_NUMBER} on GitHub and pull the result."
        return 0
    fi

    # Pull the merge commit so the version bump (and tag) build on the right
    # base. The merge commit is already on origin via gh pr merge.
    info "Pulling merged ${B_GREEN}${TARGET_BRANCH}${RESET} from ${REMOTE}…"
    git fetch "$REMOTE" "$TARGET_BRANCH" >/dev/null 2>&1 \
        || die "Could not fetch ${TARGET_BRANCH} after merge"
    git checkout "$TARGET_BRANCH" >/dev/null 2>&1 \
        || die "Could not checkout ${TARGET_BRANCH}"
    git reset --hard "$REMOTE/$TARGET_BRANCH" >/dev/null 2>&1
    SQUASH_SHA="$(git rev-parse --short=12 HEAD)"
    # The merge commit IS on origin (GitHub put it there). Reflect that in
    # the summary so the operator doesn't think nothing was pushed.
    PUSHED_BRANCH=true
    ok "Merged: ${BOLD}${B_GREEN}$MERGE_MSG${RESET}"
    ok "Commit: ${BOLD}${SQUASH_SHA}${RESET}"
}

# ─── Push step ───────────────────────────────────────────────────────────────

# Pushes whatever local-only commits and tags the post-merge phase produced
# (typically: a chore: bump-version commit on top of the merge commit, plus
# a v* tag). The merge itself is already on origin via merge_on_github, so
# we skip the branch push when HEAD is in sync.
push_changes() {
    section "Pushing post-merge changes to ${REMOTE}"

    if [[ "$NO_COMMIT" == true ]]; then
        info "Skipped — --no-commit means there is no merge commit to push."
        return 0
    fi

    if [[ "$NO_PUSH" == true ]]; then
        info "Skipped (--no-push). Version-bump commit and tag remain local."
        return 0
    fi

    local ahead=0
    if [[ "$DRY_RUN" != true ]]; then
        ahead="$(git rev-list --count "$REMOTE/$TARGET_BRANCH..HEAD" 2>/dev/null || echo 0)"
    fi

    if [[ "$ahead" -gt 0 ]]; then
        info "Pushing ${BOLD}$TARGET_BRANCH${RESET} (${ahead} local commit(s) ahead)…"
        if run git push "$REMOTE" "$TARGET_BRANCH"; then
            ok "Pushed ${BOLD}$TARGET_BRANCH${RESET} → ${BRIGHT_CYAN}$REPO${RESET}"
        else
            die "Failed to push $TARGET_BRANCH to $REMOTE. Resolve and re-run, or pass --no-push."
        fi
    else
        info "Branch ${BOLD}$TARGET_BRANCH${RESET} already in sync with ${REMOTE}."
    fi

    if [[ -n "$NEW_TAG" ]]; then
        info "Pushing tag ${BOLD}$NEW_TAG${RESET}…"
        # Lightweight tags don't ride along on --follow-tags, so push by name.
        if run git push "$REMOTE" "$NEW_TAG"; then
            ok "Pushed tag ${BOLD}${B_MAGENTA}$NEW_TAG${RESET}"
            PUSHED_TAG="$NEW_TAG"
        else
            warn "Failed to push tag $NEW_TAG (continuing — push manually with: git push $REMOTE $NEW_TAG)"
        fi
    fi
}

# ─── Verify PR state & post follow-up comment ────────────────────────────────

# After merge_on_github, GitHub has already marked the PR as MERGED and
# auto-deleted the head branch. This step verifies state and (optionally)
# adds a comment with the version tag — the merge SHA is already visible
# on the PR via GitHub's own "Merged via commit X" notice.
close_pr() {
    section "Confirming PR #${PR_NUMBER}"

    if [[ "$NO_COMMIT" == true ]]; then
        info "Skipped — --no-commit leaves the PR untouched."
        PR_CLOSE_STATUS="skipped"
        return 0
    fi

    if [[ "$NO_CLOSE_PR" == true ]]; then
        info "Skipped (--no-close-pr)."
        PR_CLOSE_STATUS="skipped"
        return 0
    fi

    if [[ "$DRY_RUN" == true ]]; then
        info "Would verify PR #${PR_NUMBER} is MERGED."
        return 0
    fi

    local state
    state="$(gh pr view "$PR_NUMBER" --repo "$REPO" --json state --jq .state 2>/dev/null || echo "")"

    case "$state" in
        MERGED)
            ok "PR #${PR_NUMBER} confirmed ${B_GREEN}MERGED${RESET} on GitHub."
            PR_CLOSE_STATUS="merged"
            ;;
        CLOSED)
            warn "PR #${PR_NUMBER} shows as CLOSED (not MERGED). Inspect on GitHub."
            PR_CLOSE_STATUS="closed-not-merged"
            return 0
            ;;
        *)
            warn "Unexpected PR state: ${state:-unknown}. Inspect on GitHub."
            PR_CLOSE_STATUS="failed"
            return 0
            ;;
    esac

    # Add a tag-reference comment only when a new tag was created. The merge
    # SHA itself is already shown by GitHub on the merged PR, so we skip
    # commenting in the tag-less case to avoid noise.
    if [[ -n "$NEW_TAG" ]]; then
        info "Posting tag-reference comment on PR #${PR_NUMBER}…"
        if run gh pr comment "$PR_NUMBER" --repo "$REPO" --body "Released as ${NEW_TAG}." >/dev/null; then
            ok "Comment posted."
        else
            warn "Could not post tag comment (continuing)."
        fi
    fi
}

# ─── Close linked issues ─────────────────────────────────────────────────────

# Closes every issue referenced via a closing keyword in the PR body
# (close/closes/closed/fix/fixes/fixed/resolve/resolves/resolved + #N).
# Idempotent per-issue: checks state first. Non-critical: warns and continues
# on per-issue failure.
close_linked_issues() {
    section "Closing linked issues"

    if [[ "$NO_CLOSE_ISSUE" == true ]]; then
        info "Skipped (--no-close-issue)."
        return
    fi

    local issues
    issues="$(extract_linked_issues)"

    if [[ -z "$issues" ]]; then
        info "No linked issue keyword found in PR body. Skipping."
        return
    fi

    local issue_num state comment
    while IFS= read -r issue_num; do
        [[ -z "$issue_num" ]] && continue

        state="$(gh issue view "$issue_num" --repo "$REPO" --json state --jq .state 2>/dev/null || echo "")"
        if [[ -z "$state" ]]; then
            warn "Issue #${issue_num} not found in $REPO — skipping"
            SKIPPED_ISSUES+=("$issue_num")
            continue
        fi
        if [[ "$state" == "CLOSED" ]]; then
            info "Issue #${issue_num} already closed."
            SKIPPED_ISSUES+=("$issue_num")
            continue
        fi

        comment="Done in ${SQUASH_SHA}"
        [[ -n "$NEW_TAG" ]] && comment="${comment} (${NEW_TAG})"
        comment="${comment}. PR #${PR_NUMBER} merged."

        info "Closing issue #${issue_num}…"
        if run gh issue close "$issue_num" --repo "$REPO" --reason completed --comment "$comment"; then
            ok "Closed issue #${issue_num}"
            CLOSED_ISSUES+=("$issue_num")
        else
            warn "Could not close issue #${issue_num} (continuing)"
            FAILED_ISSUES+=("$issue_num")
        fi
    done <<< "$issues"
}

# ─── Project board update ────────────────────────────────────────────────────

# Discovers projects owned by the repo owner, finds project items linked to
# the PR or any linked issue, and moves them to the Status field's "Done"
# option. Field id and option id are discovered at runtime by name match
# (case-insensitive). Non-critical: warns and continues on any failure.
# Requires the gh `project` scope; the user can grant it with:
#   gh auth refresh -s project,read:project
update_project_item() {
    section "Updating project board"

    if [[ "$NO_PROJECT_UPDATE" == true ]]; then
        info "Skipped (--no-project-update)."
        return 0
    fi

    local owner="${REPO%%/*}"

    local projects
    if ! projects="$(gh project list --owner "$owner" --format json 2>/dev/null)"; then
        info "Could not list projects for $owner (missing 'project' scope?). Skipping."
        info "  Grant it with: ${BOLD}gh auth refresh -s project,read:project${RESET}"
        return 0
    fi

    local project_count
    project_count="$(echo "$projects" | jq '.projects | length' 2>/dev/null || echo 0)"
    if [[ "$project_count" == "0" || -z "$project_count" ]]; then
        info "No projects found for $owner. Skipping."
        return 0
    fi

    # Build target number set: the PR plus any linked issues from the PR body.
    # These are the auto-matched candidates that get preselected (green dot).
    local -a targets=("$PR_NUMBER")
    local linked n
    linked="$(extract_linked_issues)"
    while IFS= read -r n; do
        [[ -n "$n" ]] && targets+=("$n")
    done <<< "$linked"

    # JSON array literal for the jq filter. Safe to inline — every entry has
    # already been validated as an integer (PR_NUMBER) or matched by digit
    # regex (extract_linked_issues).
    local targets_json
    targets_json="$(IFS=,; echo "[${targets[*]}]")"

    # Parallel arrays of candidate items. Each index is one item to (maybe)
    # move; CAND_SELECTED carries its toggle state.
    local -a CAND_PROJ_TITLE=() CAND_PROJ_ID=()
    local -a CAND_FIELD_ID=() CAND_OPTION_ID=() CAND_OPTION_NAME=()
    local -a CAND_ITEM_ID=() CAND_ITEM_URL=() CAND_ITEM_NUMBER=() CAND_ITEM_TITLE=()
    local -a CAND_SELECTED=()

    local project_data project_number project_id project_title
    local items fields status_field_id done_option_id done_option_name
    local match_line item_id item_url item_number item_title

    while IFS= read -r project_data; do
        project_number="$(echo "$project_data" | jq -r '.number')"
        project_id="$(echo "$project_data" | jq -r '.id')"
        project_title="$(echo "$project_data" | jq -r '.title')"

        items="$(gh project item-list "$project_number" --owner "$owner" --format json --limit 200 2>/dev/null)" || continue
        fields="$(gh project field-list "$project_number" --owner "$owner" --format json 2>/dev/null)" || continue

        status_field_id="$(echo "$fields" | jq -r '[.fields[] | select((.name // "") | ascii_downcase == "status")][0].id // empty')"
        [[ -z "$status_field_id" ]] && continue

        done_option_id="$(echo "$fields" | jq -r '[.fields[] | select((.name // "") | ascii_downcase == "status")][0].options[]? | select((.name // "") | ascii_downcase == "done") | .id' | head -1)"
        done_option_name="$(echo "$fields" | jq -r '[.fields[] | select((.name // "") | ascii_downcase == "status")][0].options[]? | select((.name // "") | ascii_downcase == "done") | .name' | head -1)"
        [[ -z "$done_option_id" ]] && continue

        # Critical scoping: only items whose .content.repository matches the
        # current repo AND whose number is one of our targets. Without the
        # repository filter, items with the same issue number in OTHER repos
        # inside the same project would be moved (the Colibri/#24 bug).
        while IFS= read -r match_line; do
            [[ -z "$match_line" ]] && continue
            IFS=$'\t' read -r item_id item_url item_number item_title <<< "$match_line"
            [[ -z "$item_id" ]] && continue
            CAND_PROJ_TITLE+=("$project_title")
            CAND_PROJ_ID+=("$project_id")
            CAND_FIELD_ID+=("$status_field_id")
            CAND_OPTION_ID+=("$done_option_id")
            CAND_OPTION_NAME+=("$done_option_name")
            CAND_ITEM_ID+=("$item_id")
            CAND_ITEM_URL+=("$item_url")
            CAND_ITEM_NUMBER+=("$item_number")
            CAND_ITEM_TITLE+=("$item_title")
            CAND_SELECTED+=("true")
        done < <(echo "$items" | jq -r \
            --arg repo "$REPO" \
            --argjson nums "$targets_json" \
            '.items[]?
             | select((.content.repository // "") == $repo)
             | (.content.number // 0) as $n
             | select($nums | index($n))
             | "\(.id)\t\(.content.url // "")\t\($n)\t\(.content.title // "")"')
    done <<< "$(echo "$projects" | jq -c '.projects[]?')"

    local total=${#CAND_ITEM_ID[@]}
    if [[ "$total" -eq 0 ]]; then
        info "No matching project items found for PR #${PR_NUMBER} or its linked issues."
        return 0
    fi

    # ── Display + toggle (mirrors the labels picker) ───────────────────────
    echo ""
    echo -e "${DIM}Project items to move → ${B_GREEN}Done${RESET}${DIM} (preselected shown with ${B_GREEN}●${RESET}${DIM}):${RESET}"
    local i marker
    for ((i = 0; i < total; i++)); do
        marker=" "
        [[ "${CAND_SELECTED[$i]}" == "true" ]] && marker="${B_GREEN}●${RESET}"
        printf "  $marker ${B_MAGENTA}%2d)${RESET} ${BOLD}%s${RESET}/${B_MAGENTA}#%s${RESET} ${DIM}— %s${RESET}\n" \
            "$((i+1))" "${CAND_PROJ_TITLE[$i]}" "${CAND_ITEM_NUMBER[$i]}" "${CAND_ITEM_TITLE[$i]}"
    done
    echo ""

    local choices num idx
    read -rp "$(echo -e "${B_MAGENTA}?${RESET} ${BOLD}Numbers to toggle${RESET} ${DIM}(space-separated, empty to proceed with preselection):${RESET} ")" choices

    for num in $choices; do
        if [[ "$num" =~ ^[0-9]+$ ]]; then
            idx=$((num - 1))
            if [[ "$idx" -ge 0 && "$idx" -lt "$total" ]]; then
                if [[ "${CAND_SELECTED[$idx]}" == "true" ]]; then
                    CAND_SELECTED[$idx]="false"
                else
                    CAND_SELECTED[$idx]="true"
                fi
            fi
        fi
    done

    # ── Apply selected items ───────────────────────────────────────────────
    local any_selected=false
    for ((i = 0; i < total; i++)); do
        [[ "${CAND_SELECTED[$i]}" == "true" ]] || continue
        any_selected=true
        # Log the exact item URL before mutating so cross-repo regressions
        # are immediately visible.
        info "Moving ${BRIGHT_CYAN}${CAND_ITEM_URL[$i]:-#${CAND_ITEM_NUMBER[$i]}}${RESET} in ${BOLD}${CAND_PROJ_TITLE[$i]}${RESET} → ${B_GREEN}${CAND_OPTION_NAME[$i]}${RESET}…"
        if run gh project item-edit \
                --id "${CAND_ITEM_ID[$i]}" \
                --field-id "${CAND_FIELD_ID[$i]}" \
                --project-id "${CAND_PROJ_ID[$i]}" \
                --single-select-option-id "${CAND_OPTION_ID[$i]}" >/dev/null; then
            ok "Moved ${CAND_PROJ_TITLE[$i]}/#${CAND_ITEM_NUMBER[$i]} to ${B_GREEN}${CAND_OPTION_NAME[$i]}${RESET}"
            PROJECT_ITEMS_MOVED+=("${CAND_PROJ_TITLE[$i]} → ${CAND_OPTION_NAME[$i]} (${CAND_ITEM_URL[$i]:-#${CAND_ITEM_NUMBER[$i]}})")
        else
            warn "Could not update ${CAND_ITEM_URL[$i]:-#${CAND_ITEM_NUMBER[$i]}} in ${CAND_PROJ_TITLE[$i]} (continuing)"
            PROJECT_ITEMS_FAILED+=("${CAND_PROJ_TITLE[$i]} (${CAND_ITEM_URL[$i]:-#${CAND_ITEM_NUMBER[$i]}})")
        fi
    done

    if [[ "$any_selected" != true ]]; then
        info "All items deselected — nothing moved."
    fi
}

# ─── Thank author ────────────────────────────────────────────────────────────

thank_author() {
    if [[ "$NO_THANKS" == true ]]; then
        THANK_STATUS="skipped"
        return 0
    fi

    # Self-merge: skip silently. Don't prompt the user to thank themselves.
    local me
    me="$(gh api user --jq .login 2>/dev/null || echo "")"
    if [[ -n "$me" && "$me" == "$PR_AUTHOR" ]]; then
        THANK_STATUS="skipped"
        return 0
    fi

    echo ""
    if ! ask_yes_no "Thank ${BRIGHT_CYAN}@${PR_AUTHOR}${RESET} on the PR?" "y"; then
        THANK_STATUS="skipped"
        return 0
    fi

    if run gh api "repos/$REPO/issues/$PR_NUMBER/comments" -f body="Thank you @$PR_AUTHOR!" >/dev/null; then
        ok "Posted a thank-you comment on PR #${PR_NUMBER}"
        THANK_STATUS="posted"
    else
        warn "Could not post comment (check your token permissions)"
        THANK_STATUS="failed"
    fi
}

# ─── Final summary ───────────────────────────────────────────────────────────

print_summary() {
    section "Summary"

    if [[ "$DRY_RUN" == true ]]; then
        echo -e "  ${BOLD}${B_YELLOW}DRY RUN${RESET} — no state was changed."
        echo ""
    fi

    echo -e "  ${DIM}Merge commit:${RESET}     ${BOLD}${SQUASH_SHA:-—}${RESET}"
    echo -e "  ${DIM}Tag:${RESET}              ${BOLD}${NEW_TAG:-—}${RESET}"

    local push_str="${B_YELLOW}skipped${RESET}"
    if [[ "$PUSHED_BRANCH" == true ]]; then
        push_str="${B_GREEN}✔${RESET} ${TARGET_BRANCH}"
        [[ -n "$PUSHED_TAG" ]] && push_str="${push_str} + ${PUSHED_TAG}"
    fi
    echo -e "  ${DIM}Pushed:${RESET}           $push_str"

    local pr_str
    case "$PR_CLOSE_STATUS" in
        merged)            pr_str="${B_GREEN}✔${RESET} merged (#${PR_NUMBER})" ;;
        closed-not-merged) pr_str="${B_RED}closed but not merged${RESET} — inspect on GitHub" ;;
        skipped)           pr_str="${B_YELLOW}skipped${RESET}" ;;
        failed)            pr_str="${B_RED}failed${RESET}" ;;
        *)                 pr_str="${DIM}—${RESET}" ;;
    esac
    echo -e "  ${DIM}PR:${RESET}               $pr_str"

    local issues_str=""
    if [[ ${#CLOSED_ISSUES[@]} -gt 0 ]]; then
        issues_str="${B_GREEN}✔${RESET} #$(IFS=,; echo "${CLOSED_ISSUES[*]}")"
    fi
    if [[ ${#SKIPPED_ISSUES[@]} -gt 0 ]]; then
        [[ -n "$issues_str" ]] && issues_str="$issues_str  "
        issues_str="${issues_str}${DIM}skipped: #$(IFS=,; echo "${SKIPPED_ISSUES[*]}")${RESET}"
    fi
    if [[ ${#FAILED_ISSUES[@]} -gt 0 ]]; then
        [[ -n "$issues_str" ]] && issues_str="$issues_str  "
        issues_str="${issues_str}${B_RED}failed: #$(IFS=,; echo "${FAILED_ISSUES[*]}")${RESET}"
    fi
    [[ -z "$issues_str" ]] && issues_str="${DIM}—${RESET}"
    echo -e "  ${DIM}Issues:${RESET}           $issues_str"

    local proj_str=""
    if [[ ${#PROJECT_ITEMS_MOVED[@]} -gt 0 ]]; then
        local m
        for m in "${PROJECT_ITEMS_MOVED[@]}"; do
            proj_str="${proj_str:+${proj_str}; }${B_GREEN}✔${RESET} $m"
        done
    fi
    if [[ ${#PROJECT_ITEMS_FAILED[@]} -gt 0 ]]; then
        local f
        for f in "${PROJECT_ITEMS_FAILED[@]}"; do
            proj_str="${proj_str:+${proj_str}; }${B_RED}failed${RESET} $f"
        done
    fi
    [[ -z "$proj_str" ]] && proj_str="${DIM}—${RESET}"
    echo -e "  ${DIM}Project board:${RESET}    $proj_str"

    local thank_str
    case "$THANK_STATUS" in
        posted)  thank_str="${B_GREEN}✔${RESET} posted" ;;
        skipped) thank_str="${B_YELLOW}skipped${RESET}" ;;
        failed)  thank_str="${B_RED}failed${RESET}" ;;
        *)       thank_str="${DIM}—${RESET}" ;;
    esac
    echo -e "  ${DIM}Thank-you:${RESET}        $thank_str"
    echo ""
}

# ─── Parse arguments ─────────────────────────────────────────────────────────

PR_NUMBER=""
SWITCH_BRANCH=""
NO_COMMIT=false
NO_THANKS=false
FORCE_SQUASH=false
NO_PUSH=false
NO_CLOSE_PR=false
NO_CLOSE_ISSUE=false
NO_PROJECT_UPDATE=false
DRY_RUN=false
SELECTED_TYPE=""

# Tracking state for the final summary.
SQUASH_SHA=""
NEW_TAG=""
PUSHED_BRANCH=false
PUSHED_TAG=""
PR_CLOSE_STATUS=""        # one of: closed, already-closed, auto-merged, skipped, failed, dry-run
THANK_STATUS=""           # one of: posted, skipped, failed, dry-run
CLOSED_ISSUES=()
SKIPPED_ISSUES=()
FAILED_ISSUES=()
PROJECT_ITEMS_MOVED=()
PROJECT_ITEMS_FAILED=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help) usage ;;
        -s|--switch)
            SWITCH_BRANCH="$2"; shift 2 ;;
        --switch=*)
            SWITCH_BRANCH="${1#*=}"; shift ;;
        --no-commit)
            NO_COMMIT=true; shift ;;
        --no-thanks)
            NO_THANKS=true; shift ;;
        --force-squash)
            FORCE_SQUASH=true; shift ;;
        --no-push)
            NO_PUSH=true; shift ;;
        --no-close-pr)
            NO_CLOSE_PR=true; shift ;;
        --no-close-issue)
            NO_CLOSE_ISSUE=true; shift ;;
        --no-project-update)
            NO_PROJECT_UPDATE=true; shift ;;
        --dry-run)
            DRY_RUN=true; shift ;;
        -*)
            die "Unknown option: $1" ;;
        *)
            [[ -n "$PR_NUMBER" ]] && die "Unexpected argument: $1"
            PR_NUMBER="$1"; shift ;;
    esac
done

[[ -z "$PR_NUMBER" ]] && die "Missing required argument: PR number. Run birb merge --help for usage."
[[ "$PR_NUMBER" =~ ^[0-9]+$ ]] || die "PR number must be a positive integer, got: $PR_NUMBER"

# ─── Prerequisites ───────────────────────────────────────────────────────────

command -v gh >/dev/null || die "gh (GitHub CLI) is required. Install: https://cli.github.com"
command -v jq >/dev/null || die "jq is required. Install: brew install jq"
git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "Not inside a git repository"

REMOTE="$(get_remote)"
REPO="$(get_repo_slug "$REMOTE")"

header "PR #${PR_NUMBER} on ${REPO}"

info "Remote: ${BOLD}$REMOTE${RESET}  ${DIM}→${RESET}  ${BOLD}${BRIGHT_CYAN}$REPO${RESET}"

# ─── Fetch PR data ───────────────────────────────────────────────────────────

info "Fetching PR details…"

PR_JSON="$(gh api "repos/$REPO/pulls/$PR_NUMBER" 2>/dev/null)" \
    || die "Could not fetch PR #${PR_NUMBER}. Is it a valid PR in $REPO?"

PR_TITLE="$(echo "$PR_JSON" | jq -r '.title')"
PR_STATE="$(echo "$PR_JSON" | jq -r '.state')"
PR_AUTHOR="$(echo "$PR_JSON" | jq -r '.user.login')"
PR_HEAD_REF="$(echo "$PR_JSON" | jq -r '.head.ref')"
PR_BASE_REF="$(echo "$PR_JSON" | jq -r '.base.ref')"
PR_MERGED="$(echo "$PR_JSON" | jq -r '.merged')"

TARGET_BRANCH="${SWITCH_BRANCH:-$PR_BASE_REF}"

echo ""
echo -e "  ${BOLD}${B_MAGENTA}#${PR_NUMBER}${RESET}  ${BOLD}$PR_TITLE${RESET}"
echo -e "  ${DIM}Author:${RESET}  ${BRIGHT_CYAN}@${PR_AUTHOR}${RESET}"
echo -e "  ${DIM}Branch:${RESET}  ${YELLOW}$PR_HEAD_REF${RESET} ${DIM}→${RESET} ${B_GREEN}$TARGET_BRANCH${RESET}"
echo -e "  ${DIM}State:${RESET}   ${GREEN}$PR_STATE${RESET}"

[[ "$PR_MERGED" == "true" ]] && { echo ""; die "PR #${PR_NUMBER} is already merged."; }
[[ "$PR_STATE" == "closed" ]] && { echo ""; die "PR #${PR_NUMBER} is closed (not merged)."; }

# ─── Commits / squash strategy ───────────────────────────────────────────────

COMMITS_JSON="$(gh api "repos/$REPO/pulls/$PR_NUMBER/commits?per_page=100" 2>/dev/null)"
COMMIT_COUNT="$(echo "$COMMITS_JSON" | jq 'length')"
AUTHOR_COUNT="$(echo "$COMMITS_JSON" | jq '[.[].author.login // .[].commit.author.name] | unique | length')"

echo -e "  ${DIM}Commits:${RESET} ${BOLD}$COMMIT_COUNT${RESET} by ${BOLD}$AUTHOR_COUNT${RESET} author(s)"

# ─── Ensure working tree is clean ────────────────────────────────────────────

if [[ -n "$(git status --porcelain 2>/dev/null)" ]]; then
    echo ""
    die "Working tree is dirty. Please commit or stash your changes first."
fi

# ─── Interactive prompts ─────────────────────────────────────────────────────

select_commit_type
manage_labels

# Decide squash strategy
section "Squash strategy"
SQUASH=false
if [[ "$COMMIT_COUNT" -eq 1 ]]; then
    info "Single commit — will squash by default."
    SQUASH=true
elif [[ "$AUTHOR_COUNT" -gt 1 && "$FORCE_SQUASH" == false ]]; then
    warn "Multiple authors detected. Using merge commit (use --force-squash to override)."
    SQUASH=false
else
    echo -e "${DIM}PR has $COMMIT_COUNT commits.${RESET}"
    if ask_yes_no "Squash into a single commit?" "y"; then
        SQUASH=true
    fi
fi

# ─── Build merge commit message ──────────────────────────────────────────────

# Strip any existing conventional-commit prefix from PR title
stripped_title="$PR_TITLE"
if [[ "$PR_TITLE" =~ ^[a-z]+(\([a-z0-9/_-]+\))?:[[:space:]]+(.*)$ ]]; then
    stripped_title="${BASH_REMATCH[2]}"
fi

if [[ -n "$SELECTED_TYPE" ]]; then
    MERGE_MSG="$(printf '%s: %s (#%s)' "$SELECTED_TYPE" "$stripped_title" "$PR_NUMBER")"
else
    MERGE_MSG="$(printf '%s (#%s)' "$PR_TITLE" "$PR_NUMBER")"
fi

# ─── Execute the merge ───────────────────────────────────────────────────────

if [[ "$NO_COMMIT" == true ]]; then
    # Inspection-only path: do a local merge with --no-commit, then stop.
    # Useful for reviewing the cumulative diff before running for real.
    section "Local merge for inspection (--no-commit)"

    info "Fetching ${BOLD}$TARGET_BRANCH${RESET} and PR head…"
    git fetch "$REMOTE" "$TARGET_BRANCH" 2>/dev/null \
        || die "Could not fetch branch $TARGET_BRANCH from $REMOTE"
    git fetch "$REMOTE" "pull/${PR_NUMBER}/head:pr-${PR_NUMBER}" 2>/dev/null \
        || die "Could not fetch PR #${PR_NUMBER} head"

    info "Checking out ${B_GREEN}${TARGET_BRANCH}${RESET}…"
    git checkout "$TARGET_BRANCH" 2>/dev/null || die "Could not checkout $TARGET_BRANCH"
    git reset --hard "$REMOTE/$TARGET_BRANCH" >/dev/null 2>&1

    if [[ "$SQUASH" == true ]]; then
        git merge --squash "pr-${PR_NUMBER}" >/dev/null 2>&1 \
            || die "Merge failed. Resolve conflicts and run: git commit"
        ok "Squash-merged (no commit). Review with: ${BOLD}git diff --cached${RESET}"
    else
        git merge --no-ff --no-commit "pr-${PR_NUMBER}" >/dev/null 2>&1 \
            || die "Merge failed. Resolve conflicts and run: git commit"
        ok "Merged (no commit). Review with: ${BOLD}git diff --cached${RESET}"
    fi

    git branch -D "pr-${PR_NUMBER}" >/dev/null 2>&1 || true

    section "Local merge complete"
    info "Skipping push / close / project steps because of --no-commit."
    info "Review with ${BOLD}git diff --cached${RESET}, finish the commit, then push manually."
    echo ""
else
    # Default path: let GitHub perform the merge. This is what makes the PR
    # show as MERGED (not just closed) and triggers auto-rebase of stacked
    # PRs when the head branch is deleted.
    merge_on_github
    manage_version_bump
    push_changes
    close_pr
    close_linked_issues
    update_project_item
    thank_author
fi

print_summary
